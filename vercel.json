{
  "routes": [
    {
      "src": "/v3",
      "dest": "/index_v3.html"
    },
    {
      "src": "/v2",
      "dest": "/index_v2_1.html"
    },
    {
      "src": "/v1",
      "dest": "/index.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
